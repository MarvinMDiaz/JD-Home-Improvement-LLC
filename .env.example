# Flask - set a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Amazon SES - verify From/To identities (or domain) in the SES console
# https://docs.aws.amazon.com/ses/latest/dg/send-email.html
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@yourdomain.com
SES_TO_EMAIL=hello@yourdomain.com

# Local dev: log the message instead of calling SES (omit or set to 0 in production)
CONTACT_DRY_RUN=1
